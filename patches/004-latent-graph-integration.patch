diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 4444444..5555555 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -0,0 +1,80 @@
+// LATENT: build the low-rank fused expert FFN graph
+ggml_tensor * llm_graph_context::build_moe_ffn_latent(
+         ggml_tensor * cur,
+         ggml_tensor * gate_inp,
+         ggml_tensor * gate_a, ggml_tensor * gate_a_scale,
+         ggml_tensor * gate_b, ggml_tensor * gate_b_scale,
+         ggml_tensor * up_a,   ggml_tensor * up_a_scale,
+         ggml_tensor * up_b,   ggml_tensor * up_b_scale,
+         ggml_tensor * down_a, ggml_tensor * down_a_scale,
+         ggml_tensor * down_b, ggml_tensor * down_b_scale,
+         ggml_tensor * exp_probs_b,
+             int64_t   n_expert,
+             int64_t   n_expert_used,
+     llama_expert_gating_func_type gating_op,
+                bool   norm_w,
+               float   w_scale,
+                 int   il,
+         ggml_tensor * probs_in,
+         ggml_tensor * selected_experts_in,
+                bool   weight_before_down) const {
+    const int64_t n_embd   = cur->ne[0];
+    const int64_t n_tokens = cur->ne[1];
+
+    // 1. Compute router logits (same as dense path)
+    ggml_tensor * logits = nullptr;
+    if (probs_in == nullptr) {
+        logits = build_lora_mm(gate_inp, cur);
+        cb(logits, "ffn_moe_logits", il);
+    } else {
+        logits = probs_in;
+    }
+
+    if (exp_probs_b != nullptr) {
+        logits = ggml_add(ctx0, logits, exp_probs_b);
+        cb(logits, "ffn_moe_logits_biased", il);
+    }
+
+    // 2. Select top-k experts (same as dense path)
+    ggml_tensor * selected_experts = selected_experts_in;
+    if (selected_experts == nullptr) {
+        selected_experts = ggml_argsort_top_k(ctx0, logits, n_expert_used);
+        cb(selected_experts, "ffn_moe_topk", il);
+    }
+
+    // 3. Get expert weights from router scores
+    ggml_tensor * probs = build_lora_mm(gate_inp, cur);
+    cb(probs, "ffn_moe_probs", il);
+    probs = ggml_reshape_3d(ctx0, probs, 1, n_expert, n_tokens);
+    ggml_tensor * weights = ggml_get_rows(ctx0, probs, selected_experts);
+    cb(weights, "ffn_moe_weights", il);
+
+    if (norm_w) {
+        weights = ggml_reshape_2d(ctx0, weights, n_expert_used, n_tokens);
+        ggml_tensor * weights_sum = ggml_sum_rows(ctx0, weights);
+        weights_sum = ggml_clamp(ctx0, weights_sum, 6.103515625e-5, INFINITY);
+        weights = ggml_div(ctx0, weights, weights_sum);
+        weights = ggml_reshape_3d(ctx0, weights, 1, n_expert_used, n_tokens);
+    }
+
+    if (w_scale != 0.0f && w_scale != 1.0f) {
+        weights = ggml_scale(ctx0, weights, w_scale);
+    }
+
+    ggml_build_forward_expand(gf, weights);
+
+    // 4. Reshape input for the fused kernel
+    cur = ggml_reshape_3d(ctx0, cur, n_embd, 1, n_tokens);
+
+    // 5. Build the LATENT fused expert FFN op
+    const int64_t max_rank = gate_a->ne[1];
+    const int64_t n_ff = gate_b->ne[1];
+
+    ggml_tensor * latent_out = ggml_latent_expert_ffn(
+        ctx0, cur, selected_experts, weights,
+        gate_a, gate_a_scale, gate_b, gate_b_scale,
+        up_a, up_a_scale, up_b, up_b_scale,
+        down_a, down_a_scale, down_b, down_b_scale,
+        n_embd, n_ff, n_expert_used, weight_before_down ? 1 : 0);
+    cb(latent_out, "ffn_latent_out", il);
+    ggml_build_forward_expand(gf, latent_out);
+
+    return latent_out;
+}
diff --git a/ggml/include/ggml.h b/ggml/include/ggml.h
index 6666666..7777777 100644
--- a/ggml/include/ggml.h
+++ b/ggml/include/ggml.h
@@ -0,0 +1,30 @@
+// LATENT: build graph op for fused low-rank expert FFN
+// x: [n_embd, 1, n_tokens] - hidden state
+// ids: [n_expert_used, n_tokens] - selected expert indices
+// weights: [1, n_expert_used, n_tokens] - expert weights
+// gate_a/gate_b/up_a/up_b/down_a/down_b: [n_expert, in_dim, max_rank] / [n_expert, max_rank, out_dim] NF4 packed
+// *_scale: [n_expert, groups] FP16 per-group scales
+// returns: [n_embd, 1, n_tokens] - aggregated expert output
+struct ggml_tensor * ggml_latent_expert_ffn(
+        struct ggml_context * ctx,
+        struct ggml_tensor * x,
+        struct ggml_tensor * ids,
+        struct ggml_tensor * weights,
+        struct ggml_tensor * gate_a, struct ggml_tensor * gate_a_scale,
+        struct ggml_tensor * gate_b, struct ggml_tensor * gate_b_scale,
+        struct ggml_tensor * up_a,   struct ggml_tensor * up_a_scale,
+        struct ggml_tensor * up_b,   struct ggml_tensor * up_b_scale,
+        struct ggml_tensor * down_a, struct ggml_tensor * down_a_scale,
+        struct ggml_tensor * down_b, struct ggml_tensor * down_b_scale,
+        int64_t hidden_size,
+        int64_t intermediate_size,
+        int64_t top_k,
+        int64_t weight_before_down);
diff --git a/src/ggml.c b/src/ggml.c
index 8888888..9999999 100644
--- a/src/ggml.c
+++ b/src/ggml.c
@@ -0,0 +1,40 @@
+// LATENT: graph op builder for fused low-rank expert FFN
+struct ggml_tensor * ggml_latent_expert_ffn(
+        struct ggml_context * ctx,
+        struct ggml_tensor * x,
+        struct ggml_tensor * ids,
+        struct ggml_tensor * weights,
+        struct ggml_tensor * gate_a, struct ggml_tensor * gate_a_scale,
+        struct ggml_tensor * gate_b, struct ggml_tensor * gate_b_scale,
+        struct ggml_tensor * up_a,   struct ggml_tensor * up_a_scale,
+        struct ggml_tensor * up_b,   struct ggml_tensor * up_b_scale,
+        struct ggml_tensor * down_a, struct ggml_tensor * down_a_scale,
+        struct ggml_tensor * down_b, struct ggml_tensor * down_b_scale,
+        int64_t hidden_size,
+        int64_t intermediate_size,
+        int64_t top_k,
+        int64_t weight_before_down) {
+    GGML_ASSERT(x->ne[0] == hidden_size);
+    GGML_ASSERT(ids->ne[0] == top_k);
+    GGML_ASSERT(weights->ne[1] == top_k);
+
+    struct ggml_tensor * out = ggml_new_tensor_3d(ctx, GGML_TYPE_F16, hidden_size, 1, x->ne[2]);
+
+    struct ggml_tensor * src[15] = {
+        x, ids, weights,
+        gate_a, gate_a_scale, gate_b, gate_b_scale,
+        up_a, up_a_scale, up_b, up_b_scale,
+        down_a, down_a_scale, down_b, down_b_scale,
+    };
+    for (int i = 0; i < 15; ++i) {
+        GGML_ASSERT(src[i] != nullptr);
+    }
+
+    ggml_set_op_params(out, 4, (const int32_t *) &hidden_size);
+    // op_params: [0]=hidden_size, [1]=intermediate_size, [2]=top_k, [3]=weight_before_down
+    int32_t params[4] = {(int32_t) hidden_size, (int32_t) intermediate_size, (int32_t) top_k, (int32_t) weight_before_down};
+    ggml_set_op_params(out, 4, params);
+
+    return ggml_build_forward_impl(ctx, out, 15, src, GGML_OP_LATENT_EXPERT_FFN);
+}
