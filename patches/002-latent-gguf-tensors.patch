diff --git a/src/models/deepseek4.cpp b/src/models/deepseek4.cpp
index 5555555..6666666 100644
--- a/src/models/deepseek4.cpp
+++ b/src/models/deepseek4.cpp
@@ -140,6 +140,42 @@ void llama_model_deepseek4::load_arch_tensors(llama_model_loader &) {
             layer.ffn_up_shexp   = create_tensor(tn(LLM_TENSOR_FFN_UP_SHEXP,   "weight", i), {n_embd,   n_ff_exp * n_expert_shared}, 0);
         }
 
+        // LATENT: low-rank expert factors (loaded instead of dense experts when using LATENT)
+        // A factors: [n_embd, rank], B factors: [rank, n_ff_exp] for gate/up
+        // A factors: [n_ff_exp, rank], B factors: [rank, n_embd] for down
+        // Note: rank is per-expert variable, but we allocate max rank for all experts
+        // The actual rank is stored in tensor metadata or derived from tensor shape
+        const int64_t max_rank = 128; // max rank per LATENT spec
+        const int64_t n_ff = n_ff_exp;
+        const int64_t n_expert = hparams.n_expert;
+
+        // Gate factors: A [n_embd, max_rank, n_expert], B [max_rank, n_ff, n_expert]
+        layer.ffn_latent_gate_a = create_tensor(tn(LLM_TENSOR_FFN_LATENT_GATE_A, "weight", i), {n_embd, max_rank, n_expert}, 0);
+        layer.ffn_latent_gate_b = create_tensor(tn(LLM_TENSOR_FFN_LATENT_GATE_B, "weight", i), {max_rank, n_ff, n_expert}, 0);
+        // Scales: per-expert, per-group (group size 32)
+        layer.ffn_latent_gate_a_scale = create_tensor(tn(LLM_TENSOR_FFN_LATENT_GATE_A_SCALE, "weight", i), {n_expert, (n_embd * max_rank + 31) / 32}, 0);
+        layer.ffn_latent_gate_b_scale = create_tensor(tn(LLM_TENSOR_FFN_LATENT_GATE_B_SCALE, "weight", i), {n_expert, (max_rank * n_ff + 31) / 32}, 0);
+
+        // Up factors: A [n_embd, max_rank, n_expert], B [max_rank, n_ff, n_expert]
+        layer.ffn_latent_up_a = create_tensor(tn(LLM_TENSOR_FFN_LATENT_UP_A, "weight", i), {n_embd, max_rank, n_expert}, 0);
+        layer.ffn_latent_up_b = create_tensor(tn(LLM_TENSOR_FFN_LATENT_UP_B, "weight", i), {max_rank, n_ff, n_expert}, 0);
+        layer.ffn_latent_up_a_scale = create_tensor(tn(LLM_TENSOR_FFN_LATENT_UP_A_SCALE, "weight", i), {n_expert, (n_embd * max_rank + 31) / 32}, 0);
+        layer.ffn_latent_up_b_scale = create_tensor(tn(LLM_TENSOR_FFN_LATENT_UP_B_SCALE, "weight", i), {n_expert, (max_rank * n_ff + 31) / 32}, 0);
+
+        // Down factors: A [n_ff, max_rank, n_expert], B [max_rank, n_embd, n_expert]
+        layer.ffn_latent_down_a = create_tensor(tn(LLM_TENSOR_FFN_LATENT_DOWN_A, "weight", i), {n_ff, max_rank, n_expert}, 0);
+        layer.ffn_latent_down_b = create_tensor(tn(LLM_TENSOR_FFN_LATENT_DOWN_B, "weight", i), {max_rank, n_embd, n_expert}, 0);
+        layer.ffn_latent_down_a_scale = create_tensor(tn(LLM_TENSOR_FFN_LATENT_DOWN_A_SCALE, "weight", i), {n_expert, (n_ff * max_rank + 31) / 32}, 0);
+        layer.ffn_latent_down_b_scale = create_tensor(tn(LLM_TENSOR_FFN_LATENT_DOWN_B_SCALE, "weight", i), {n_expert, (max_rank * n_embd + 31) / 32}, 0);
+
         // ffn_gate_inp is the router projection [n_embd, n_expert]
         // ffn_gate_exps is the gate projection for experts [n_embd, n_ff_exp, n_expert]
         // ffn_up_exps is the up projection for experts [n_embd, n_ff_exp, n_expert]