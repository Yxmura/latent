diff --git a/ggml/src/ggml-cuda/latent-fused-expert-ffn.cu b/ggml/src/ggml-cuda/latent-fused-expert-ffn.cu
new file mode 100755
index 0000000..2222222
--- /dev/null
+++ b/ggml/src/ggml-cuda/latent-fused-expert-ffn.cu
@@ -0,0 +1,121 @@
+#include "latent-fused-expert-ffn.cuh"
+
+LATENT_DEVICE float latent_nf4_value(uint8_t code) {
+    // NF4 codebook from QLoRA/bitsandbytes. Keep this in sync with loader.
+    constexpr float table[16] = {
+        -1.0f, -0.6961928f, -0.52507305f, -0.3949175f,
+        -0.28444138f, -0.18477343f, -0.09105004f, 0.0f,
+        0.0795803f, 0.1609302f, 0.2461123f, 0.33791524f,
+        0.44070983f, 0.562617f, 0.72295684f, 1.0f,
+    };
+    return table[code & 0x0F];
+}
+
+LATENT_DEVICE float latent_load_nf4(const latent_nf4_matrix & matrix, int linear_index) {
+    const uint8_t packed = matrix.data[linear_index >> 1];
+    const uint8_t code = (linear_index & 1) ? (packed >> 4) : (packed & 0x0F);
+    const int group = linear_index / matrix.group_size;
+    return latent_nf4_value(code) * __half2float(matrix.scales[group]);
+}
+
+LATENT_DEVICE float latent_silu(float x) {
+    return x / (1.0f + expf(-x));
+}
+
+extern "C" LATENT_GLOBAL void latent_fused_expert_dispatch(latent_dispatch_args args) {
+    // One block per selected expert. This skeleton intentionally uses scalar
+    // accumulation so CUDA and HIP can share the same implementation while the
+    // llama.cpp integration and tensor naming are still being pinned down.
+    const int topk_slot = blockIdx.x;
+    if (topk_slot >= args.top_k) {
+        return;
+    }
+
+    const int expert_id = args.expert_ids[topk_slot];
+    if (expert_id < 0) {
+        half * out = args.expert_outputs + topk_slot * args.hidden_size;
+        for (int h = threadIdx.x; h < args.hidden_size; h += blockDim.x) {
+            out[h] = __float2half(0.0f);
+        }
+        return;
+    }
+
+    const latent_expert_factors expert = args.experts[expert_id];
+    const int gate_rank = expert.gate_a.cols;
+    const int up_rank = expert.up_a.cols;
+    const int down_rank = expert.down_a.cols;
+    extern __shared__ half smem[];
+    half * latent_gate = smem;
+    half * latent_up = latent_gate + gate_rank;
+    half * gate = latent_up + up_rank;
+    half * up = gate + args.intermediate_size;
+    half * hidden = up + args.intermediate_size;
+    half * latent_down = hidden + args.intermediate_size;
+
+    for (int r = threadIdx.x; r < gate_rank; r += blockDim.x) {
+        float gate_acc = 0.0f;
+        for (int h = 0; h < args.hidden_size; ++h) {
+            const float xv = __half2float(args.x[h]);
+            gate_acc += xv * latent_load_nf4(expert.gate_a, h * gate_rank + r);
+        }
+        latent_gate[r] = __float2half(gate_acc);
+    }
+    for (int r = threadIdx.x; r < up_rank; r += blockDim.x) {
+        float up_acc = 0.0f;
+        for (int h = 0; h < args.hidden_size; ++h) {
+            const float xv = __half2float(args.x[h]);
+            up_acc += xv * latent_load_nf4(expert.up_a, h * up_rank + r);
+        }
+        latent_up[r] = __float2half(up_acc);
+    }
+    LATENT_SYNC;
+
+    for (int i = threadIdx.x; i < args.intermediate_size; i += blockDim.x) {
+        float gate_acc = 0.0f;
+        float up_acc = 0.0f;
+        for (int r = 0; r < gate_rank; ++r) {
+            gate_acc += __half2float(latent_gate[r]) * latent_load_nf4(expert.gate_b, r * args.intermediate_size + i);
+        }
+        for (int r = 0; r < up_rank; ++r) {
+            up_acc += __half2float(latent_up[r]) * latent_load_nf4(expert.up_b, r * args.intermediate_size + i);
+        }
+        gate[i] = __float2half(gate_acc);
+        up[i] = __float2half(up_acc);
+        float hidden_value = latent_silu(gate_acc) * up_acc;
+        if (args.weight_before_down) {
+            hidden_value *= __half2float(args.expert_weights[topk_slot]);
+        }
+        hidden[i] = __float2half(hidden_value);
+    }
+    LATENT_SYNC;
+
+    for (int r = threadIdx.x; r < down_rank; r += blockDim.x) {
+        float acc = 0.0f;
+        for (int i = 0; i < args.intermediate_size; ++i) {
+            acc += __half2float(hidden[i]) * latent_load_nf4(expert.down_a, i * down_rank + r);
+        }
+        latent_down[r] = __float2half(acc);
+    }
+    LATENT_SYNC;
+
+    half * out = args.expert_outputs + topk_slot * args.hidden_size;
+    for (int h = threadIdx.x; h < args.hidden_size; h += blockDim.x) {
+        float acc = 0.0f;
+        for (int r = 0; r < down_rank; ++r) {
+            acc += __half2float(latent_down[r]) * latent_load_nf4(expert.down_b, r * args.hidden_size + h);
+        }
+        out[h] = __float2half(acc);
+    }
+}
+
+extern "C" LATENT_GLOBAL void latent_expert_reduce(latent_reduce_args args) {
+    for (int h = threadIdx.x; h < args.hidden_size; h += blockDim.x) {
+        float acc = 0.0f;
+        for (int k = 0; k < args.top_k; ++k) {
+            const float weight = args.apply_weights ? __half2float(args.expert_weights[k]) : 1.0f;
+            const float value = __half2float(args.expert_outputs[k * args.hidden_size + h]);
+            acc += weight * value;
+        }
+        args.output[h] = __float2half(acc);
+    }
+}
diff --git a/ggml/src/ggml-cuda/ggml-cuda.cu b/ggml/src/ggml-cuda/ggml-cuda.cu
index 3333333..4444444 100644
--- a/ggml/src/ggml-cuda/ggml-cuda.cu
+++ b/ggml/src/ggml-cuda/ggml-cuda.cu
@@ -0,0 +1,80 @@
+// LATENT: low-rank fused expert FFN op handler
+// src[0] = x input [n_embd]
+// src[1] = expert_ids [top_k]
+// src[2] = expert_weights [top_k]
+// src[3] = gate_a factors [n_expert, n_embd, max_rank] (uint8 NF4 packed)
+// src[4] = gate_a scales [n_expert, groups_a]
+// src[5] = gate_b factors [n_expert, max_rank, n_ff]
+// src[6] = gate_b scales [n_expert, groups_b]
+// src[7] = up_a factors [n_expert, n_embd, max_rank]
+// src[8] = up_a scales [n_expert, groups_a]
+// src[9] = up_b factors [n_expert, max_rank, n_ff]
+// src[10] = up_b scales [n_expert, groups_b]
+// src[11] = down_a factors [n_expert, n_ff, max_rank]
+// src[12] = down_a scales [n_expert, groups_a]
+// src[13] = down_b factors [n_expert, max_rank, n_embd]
+// src[14] = down_b scales [n_expert, groups_b]
+// dst = output [n_embd]
+// op_params: [0] = hidden_size, [1] = intermediate_size, [2] = top_k, [3] = weight_before_down
+
+#include "latent-fused-expert-ffn.cuh"
+
+static void ggml_cuda_latent_expert_ffn(ggml_backend_cuda_context & ctx, ggml_tensor * dst) {
+    const ggml_tensor * src0 = dst->src[0];   // x
+    const ggml_tensor * src1 = dst->src[1];   // expert_ids
+    const ggml_tensor * src2 = dst->src[2];   // expert_weights
+
+    const int64_t hidden_size = ggml_get_op_params_i32(dst, 0);
+    const int64_t intermediate_size = ggml_get_op_params_i32(dst, 1);
+    const int64_t top_k = ggml_get_op_params_i32(dst, 2);
+    const int64_t weight_before_down = ggml_get_op_params_i32(dst, 3);
+
+    const half * x_d = (const half *) src0->data;
+    const int32_t * ids_d = (const int32_t *) src1->data;
+    const half * weights_d = (const half *) src2->data;
+    half * out_d = (half *) dst->data;
+
+    // Allocate per-expert outputs scratch
+    const size_t scratch_per_expert = hidden_size * sizeof(half);
+    const size_t scratch_size = top_k * scratch_per_expert;
+    ggml_cuda_pool_alloc<half> expert_outputs(ctx.pool(), scratch_size);
+
+    // Build per-expert factor arrays from the source tensors
+    // For now, we assume the rank is the second dimension of the A factor
+    const ggml_tensor * gate_a_t = dst->src[3];
+    const int64_t max_rank = gate_a_t->ne[1];
+
+    const int64_t n_expert = gate_a_t->ne[2];
+
+    // Allocate host-side factor descriptors and copy to device
+    std::vector<latent_expert_factors> host_factors(n_expert);
+    for (int64_t e = 0; e < n_expert; ++e) {
+        latent_expert_factors & f = host_factors[e];
+        f.gate_a.data = (const uint8_t *) dst->src[3]->data + e * gate_a_t->ne[0] * max_rank / 2;
+        f.gate_a.scales = (const half *) dst->src[4]->data + e * dst->src[4]->ne[1];
+        f.gate_a.rows = gate_a_t->ne[0];
+        f.gate_a.cols = max_rank;
+        f.gate_a.group_size = 32;
+
+        f.gate_b.data = (const uint8_t *) dst->src[5]->data + e * max_rank * intermediate_size / 2;
+        f.gate_b.scales = (const half *) dst->src[6]->data + e * dst->src[6]->ne[1];
+        f.gate_b.rows = max_rank;
+        f.gate_b.cols = intermediate_size;
+        f.gate_b.group_size = 32;
+
+        f.up_a.data = (const uint8_t *) dst->src[7]->data + e * gate_a_t->ne[0] * max_rank / 2;
+        f.up_a.scales = (const half *) dst->src[8]->data + e * dst->src[8]->ne[1];
+        f.up_a.rows = gate_a_t->ne[0];
+        f.up_a.cols = max_rank;
+        f.up_a.group_size = 32;
+
+        f.up_b.data = (const uint8_t *) dst->src[9]->data + e * max_rank * intermediate_size / 2;
+        f.up_b.scales = (const half *) dst->src[10]->data + e * dst->src[10]->ne[1];
+        f.up_b.rows = max_rank;
+        f.up_b.cols = intermediate_size;
+        f.up_b.group_size = 32;
+
+        f.down_a.data = (const uint8_t *) dst->src[11]->data + e * intermediate_size * max_rank / 2;
+        f.down_a.scales = (const half *) dst->src[12]->data + e * dst->src[12]->ne[1];
+        f.down_a.rows = intermediate_size;
+        f.down_a.cols = max_rank;
+        f.down_a.group_size = 32;
+
+        f.down_b.data = (const uint8_t *) dst->src[13]->data + e * max_rank * hidden_size / 2;
+        f.down_b.scales = (const half *) dst->src[14]->data + e * dst->src[14]->ne[1];
+        f.down_b.rows = max_rank;
+        f.down_b.cols = hidden_size;
+        f.down_b.group_size = 32;
+    }
+
+    ggml_cuda_pool_alloc<latent_expert_factors> d_factors(ctx.pool(), n_expert);
+    CUDA_CHECK(cudaMemcpyAsync(d_factors.ptr, host_factors.data(),
+                n_expert * sizeof(latent_expert_factors),
+                cudaMemcpyHostToDevice, ctx.stream()));
+
+    latent_dispatch_args disp_args;
+    disp_args.x = x_d;
+    disp_args.expert_ids = ids_d;
+    disp_args.expert_weights = weights_d;
+    disp_args.experts = d_factors.ptr;
+    disp_args.expert_outputs = expert_outputs.ptr;
+    disp_args.hidden_size = (int) hidden_size;
+    disp_args.intermediate_size = (int) intermediate_size;
+    disp_args.top_k = (int) top_k;
+    disp_args.weight_before_down = (int) weight_before_down;
+
+    // Launch dispatch kernel: one block per expert, 128 threads per block
+    const int threads_per_block = 128;
+    const size_t smem_bytes = (max_rank * 2 + intermediate_size * 3) * sizeof(half);
+    if (smem_bytes > 48 * 1024) {
+        cudaFuncSetAttribute(latent_fused_expert_dispatch,
+            cudaFuncAttributeMaxDynamicSharedMemorySize, smem_bytes);
+    }
+    latent_fused_expert_dispatch<<<top_k, threads_per_block, smem_bytes, ctx.stream()>>>(disp_args);
+
+    // Launch reduce kernel
+    latent_reduce_args red_args;
+    red_args.expert_outputs = expert_outputs.ptr;
+    red_args.expert_weights = weights_d;
+    red_args.output = out_d;
+    red_args.hidden_size = (int) hidden_size;
+    red_args.top_k = (int) top_k;
+    red_args.apply_weights = weight_before_down ? 0 : 1;
+    latent_expert_reduce<<<1, threads_per_block, 0, ctx.stream()>>>(red_args);
+}
