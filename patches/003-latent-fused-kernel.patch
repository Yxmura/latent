+// ggml_latent_expert_ffn
+//
+// Build a graph node for the fused LATENT MoE expert FFN. The kernel takes:
+//   src[0]  = x               [n_embd, n_tokens]
+//   src[1]  = ids             [n_expert_used, n_tokens]  (selected_experts)
+//   src[2]  = weights         [1, n_expert_used, n_tokens] (routing weights)
+//   src[3]  = gate_a_nf4      [n_embd, max_rank]
+//   src[4]  = gate_a_scales   [n_embd/32, max_rank]
+//   src[5]  = gate_b_nf4      [max_rank, n_ff]
+//   src[6]  = gate_b_scales   [max_rank, n_ff/32]
+//   src[7]  = up_a_nf4        [n_embd, max_rank]
+//   src[8]  = up_a_scales
+//   src[9]  = up_b_nf4        [max_rank, n_ff]
+//   src[10] = up_b_scales
+//   src[11] = down_a_nf4      [n_ff, max_rank]
+//   src[12] = down_a_scales
+//   src[13] = down_b_nf4      [max_rank, n_embd]
+//   src[14] = down_b_scales
+//
+// Result: [n_embd, n_expert_used, n_tokens] contribution that the caller
+// reduces (sums) across the n_expert_used axis into [n_embd, n_tokens].
+
+struct ggml_tensor * ggml_latent_expert_ffn(
+        struct ggml_context * ctx,
+        struct ggml_tensor  * x,
+        struct ggml_tensor  * ids,
+        struct ggml_tensor  * weights,
+        struct ggml_tensor  * gate_a,
+        struct ggml_tensor  * gate_a_s,
+        struct ggml_tensor  * gate_b,
+        struct ggml_tensor  * gate_b_s,
+        struct ggml_tensor  * up_a,
+        struct ggml_tensor  * up_a_s,
+        struct ggml_tensor  * up_b,
+        struct ggml_tensor  * up_b_s,
+        struct ggml_tensor  * down_a,
+        struct ggml_tensor  * down_a_s,
+        struct ggml_tensor  * down_b,
+        struct ggml_tensor  * down_b_s) {
+    GGML_ASSERT(x);
+    GGML_ASSERT(ids);
+    GGML_ASSERT(weights);
+    GGML_ASSERT(gate_a && gate_b && up_a && up_b && down_a && down_b);
+
+    const int64_t n_embd = x->ne[0];
+    const int64_t n_tokens = x->ne[1];
+    const int64_t n_expert_used = ids->ne[0];
+    const int64_t n_ff = gate_b->ne[1];
+
+    int64_t ne[4] = { n_embd, n_expert_used, n_tokens, 1 };
+    // Output tensor: f32 because per-expert weights are applied before reduction
+    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, GGML_TYPE_F32, ne[0], ne[1], ne[2], ne[3]);
+
+    result->op = GGML_OP_LATENT_EXPERT_FFN;
+    result->src[0]  = x;
+    result->src[1]  = ids;
+    result->src[2]  = weights;
+    result->src[3]  = gate_a;
+    result->src[4]  = gate_a_s;
+    result->src[5]  = gate_b;
+    result->src[6]  = gate_b_s;
+    result->src[7]  = up_a;
+    result->src[8]  = up_a_s;
+    result->src[9]  = up_b;
+    result->src[10] = up_b_s;
+    result->src[11] = down_a;
+    result->src[12] = down_a_s;
+    result->src[13] = down_b;
+    result->src[14] = down_b_s;
+
+    return result;
+}
