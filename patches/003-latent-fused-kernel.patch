+    GGML_ABORT("ggml_cuda_latent_expert_ffn: kernel not installed; "
+               "run install.sh to copy the real v1 kernel from "
+               "kernels/latent_fused_expert_ffn.cu into "
+               "ggml/src/ggml-cuda/latent-fused-expert-ffn.cu");
+}
